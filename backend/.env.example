# 서버 포트
PORT=4000

# CORS 허용 오리진 (쉼표로 구분). 미설정 시 개발용으로 모든 오리진 허용
CORS_ORIGIN=http://localhost:5173

# (선택) Kakao REST API 키 — 장소 검색으로 추천 장소 좌표 보정 시 사용
KAKAO_REST_API_KEY=

# (선택) Anthropic Claude API 키 — LLM 기반 장소 추천 시 사용.
# 미설정 시 규칙 기반(거리/시간) 추천으로 폴백한다.
ANTHROPIC_API_KEY=

# (선택) 사내 LLM 게이트웨이 Base URL. 미설정 시 api.anthropic.com 사용.
# 예) https://jiran-llm.algorix.services/v1
ANTHROPIC_BASE_URL=

# (선택) 사용할 Claude 모델. 미설정 시 기본값 사용.
ANTHROPIC_MODEL=claude-haiku-4.5

# (선택) OSRM(오픈소스 길찾기) route API base URL — 도보/자동차 실제 도로 거리·시간 보정 시 사용.
# 미설정 시 공개 데모 서버(https://router.project-osrm.org)를 사용한다.
# 데모 서버는 SLA가 없으므로 운영 환경에서는 자체 호스팅 URL을 지정하는 것을 권장한다.
# 대중교통(transit)은 OSRM이 지원하지 않아 기존 추정치를 그대로 사용한다.
OSRM_BASE_URL=

